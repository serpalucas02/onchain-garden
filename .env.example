# --- Ethereum Sepolia deploy ---

# Public RPC (no API key needed). You can swap it for an Alchemy/Infura URL if you want.
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Deployer key. Use a THROWAWAY / dev wallet — NEVER your main account.
# (The same key controls mainnet AND testnet, so leaking it risks real funds.)
# This file (.env) is gitignored, but treat private keys as radioactive anyway.
DEPLOYER_PRIVATE_KEY=

# Optional: only needed to verify the source on Etherscan (free key at etherscan.io).
ETHERSCAN_API_KEY=
